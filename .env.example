# Plated v1 runs fully on mock data — no API keys required.

# APP_URL: The URL where this app is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# GEMINI_API_KEY: Not used in v1. Reserved for v2, when photo-based
# ingredient scanning and AI meal generation move server-side.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
